<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect /index.html to /
  RewriteRule ^index\.html$ / [R=301,L]

  # If physical file exists (like .png, .css, .js), serve it directly
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # If the request has a trailing slash (e.g., /case-studies/), 
  # check if the corresponding .html exists (e.g., /case-studies.html).
  # If so, redirect to the extensionless version (remove trailing slash).
  RewriteCond %{REQUEST_URI} ^/(.+)/$
  RewriteCond %{DOCUMENT_ROOT}/%1.html -f
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # Map extensionless URL to .html
  # Check if the requested URI + .html exists as a file.
  # We DO NOT use !-d here. We want to serve the HTML file even if an empty "Ghost" directory exists.
  RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}\.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # If the request maps to a directory and there is an index.html inside, serve it.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]

  # Custom 404 page
  ErrorDocument 404 /404.html
</IfModule>
